{
	"schemaVersion": 2,
	"slice": "data-authoring",
	"description": "Maintained Solid and StyleX DataTable authoring workflow",
	"kit": {
		"entrypoints": [
			"extensions/data-authoring/ADOPTING.md",
			"extensions/data-authoring/adoption.manifest.json"
		]
	},
	"provenance": {
		"repository": "ue-shed",
		"recordSourceCommitAtAdoption": true,
		"schema": "extensions/data-authoring/adoption/provenance.schema.json",
		"template": "extensions/data-authoring/adoption/provenance.template.json",
		"target": "ue-shed-provenance.json"
	},
	"materialize": {
		"script": "extensions/data-authoring/adoption/materialize.mjs",
		"copySemantics": "template-contents-to-target-root; manifest-entries-to-identical-relative-paths"
	},
	"copy": {
		"kernel": [
			"LICENSE",
			"Cargo.toml",
			"Cargo.lock",
			"crates/uasset-parser/Cargo.toml",
			"crates/uasset-parser/LICENSE",
			"crates/uasset-parser/src",
			"packages/protocol/package.json",
			"packages/protocol/tsconfig.json",
			"packages/protocol/src/authoring-review.ts",
			"packages/protocol/src/authoring.ts",
			"packages/protocol/src/cameras.ts",
			"packages/protocol/src/companion.ts",
			"packages/protocol/src/editor-play-session.ts",
			"packages/protocol/src/index.ts",
			"packages/authoring-sdk/package.json",
			"packages/authoring-sdk/tsconfig.json",
			"packages/authoring-sdk/tsconfig.browser.json",
			"packages/authoring-sdk/src/index.ts",
			"packages/observability/package.json",
			"packages/observability/tsconfig.json",
			"packages/observability/src/health.ts",
			"packages/observability/src/index.ts",
			"packages/unreal-assets/package.json",
			"packages/unreal-assets/tsconfig.json",
			"packages/unreal-assets/src/index.ts",
			"packages/unreal-connection/package.json",
			"packages/unreal-connection/tsconfig.json",
			"packages/unreal-connection/src/index.ts",
			"packages/unreal-connection/src/remote-control-client.ts",
			"packages/authoring-catalog/package.json",
			"packages/authoring-catalog/tsconfig.json",
			"packages/authoring-catalog/src/index.ts",
			"packages/authoring/package.json",
			"packages/authoring/tsconfig.json",
			"packages/authoring/src/draft.ts",
			"packages/authoring/src/fingerprint.ts",
			"packages/authoring/src/index.ts",
			"packages/authoring/src/joined-views.ts",
			"packages/authoring/src/live.ts",
			"packages/authoring/src/relationships.ts",
			"packages/authoring/src/review.ts",
			"packages/authoring/src/session-service.ts",
			"packages/host/package.json",
			"packages/host/tsconfig.json",
			"packages/host/src/authoring.ts",
			"packages/host/src/configuration.ts",
			"packages/host/src/file-picker.ts",
			"packages/host/src/index.ts",
			"packages/host/src/live.ts"
		],
		"owned": [
			"packages/ui/package.json",
			"packages/ui/tsconfig.json",
			"packages/ui/src/button.tsx",
			"packages/ui/src/effect-solid.tsx",
			"packages/ui/src/index.ts",
			"packages/ui/src/page-header.tsx",
			"packages/ui-theme/package.json",
			"packages/ui-theme/tsconfig.json",
			"packages/ui-theme/src/index.ts",
			"packages/ui-theme/src/themes.stylex.ts",
			"packages/ui-theme/src/tokens.stylex.ts",
			"extensions/data-authoring/package.json",
			"extensions/data-authoring/tsconfig.json",
			"extensions/data-authoring/src/authoring-combined-view.tsx",
			"extensions/data-authoring/src/authoring-grid-model.ts",
			"extensions/data-authoring/src/authoring-route.tsx",
			"extensions/data-authoring/src/authoring-table-grid.tsx",
			"extensions/data-authoring/src/authoring-view.ts",
			"extensions/data-authoring/src/index.ts"
		]
	},
	"consumerTemplate": "extensions/data-authoring/adoption/consumer",
	"toolchain": {
		"nativeReader": "cargo build --locked --release -p uasset-parser",
		"runtime": {
			"browser": "schema-validated HTTP AuthoringClient",
			"host": "ShedHostLive Node server"
		},
		"solid": "vite-plugin-solid",
		"stylex": {
			"build": "extract stylex.css",
			"serve": "set runtimeInjection to true"
		}
	},
	"conformance": {
		"sourceCommand": "pnpm test:adoption:data-authoring",
		"targetCommands": [
			"pnpm build:reader",
			"pnpm verify -- --expected-accent=#ff6b6b",
			"pnpm verify:host -- --project=<unreal-project-root> --reader=<target>/target/release/uasset.exe"
		],
		"requiresFunctionalHost": true,
		"requiresNonEmptyProjectCatalog": true,
		"requiresOpenSavedTable": true,
		"requiresNoWorkbenchImports": true,
		"requiresNonEmptyStylexCss": true,
		"requiresTokenDivergence": true
	}
}
