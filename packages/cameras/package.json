{
	"name": "@ue-shed/cameras",
	"version": "0.1.0-rc.2",
	"description": "Headless Map Review schemas, framing, capture orchestration, and camera transports.",
	"homepage": "https://github.com/ue-shed/ue-shed#readme",
	"bugs": {
		"url": "https://github.com/ue-shed/ue-shed/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ue-shed/ue-shed.git",
		"directory": "packages/cameras"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./review-contracts": {
			"types": "./dist/review-ipc.d.ts",
			"import": "./dist/review-ipc.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"contract:check": "tsx scripts/check-review-contract.ts",
		"prepack": "pnpm run build",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ue-shed/protocol": "workspace:0.1.0-rc.2",
		"@ue-shed/unreal-connection": "workspace:0.1.0-rc.2",
		"effect": "catalog:"
	},
	"engines": {
		"node": ">=22.14.0"
	}
}
