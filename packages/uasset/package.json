{
	"name": "@ue-shed/uasset",
	"version": "0.1.0-rc.1",
	"description": "Platform-selecting launcher for the UE Shed saved-asset parser",
	"homepage": "https://github.com/peculiarnewbie/ue-shed#readme",
	"bugs": {
		"url": "https://github.com/peculiarnewbie/ue-shed/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/peculiarnewbie/ue-shed.git",
		"directory": "packages/uasset"
	},
	"bin": {
		"uasset": "./bin/uasset.js"
	},
	"files": [
