{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"exactOptionalPropertyTypes": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"strict": true,
		"target": "ES2023",
		"types": ["node"]
	},
	"include": ["bin/**/*.js", "src/**/*.js"]
}
